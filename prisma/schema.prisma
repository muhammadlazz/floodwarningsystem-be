generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// enums
enum Agency {
  CITRA_BANJIR
  BBWS
  BMKG
  BPBD_JABAR
  BPBD_KAB
  SYSTEM
}

enum Role {
  SUPER_ADMIN
  MASTER_ADMIN
  ADMIN
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
}

enum ReportStatus {
  BARU
  DIPROSES
  SELESAI 
}

enum AlertStatus {
  RAWAN_BANJIR
  AMAN
}


// models
model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency    Agency?
  role      Role     @default(ADMIN)

  // Relations
  activityLogs ActivityLog[]
}

model Feedback {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  description String   @db.Text
  whatsapp    String
  isRead      Boolean  @default(false) // false = baru, true = terbaca
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id          Int       @id @default(autoincrement())
  userId      Int?
  action      LogAction
  entity      String?   // Tabel/Modul yang terdampak (misal: "User", "Report")
  description String    @db.Text
  createdAt   DateTime  @default(now())

  // Relasi ke User
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Report {
  id           Int          @id @default(autoincrement())
  reporterName String
  location     String
  impact       String       @db.Text
  status       ReportStatus @default(BARU)
  createdAt    DateTime     @default(now()) // Menjadi parameter "Waktu Laporan"
  updatedAt    DateTime     @updatedAt
}

model RegionUpdate {
  id                      Int         @id @default(autoincrement())
  regionName              String
  alertStatus             AlertStatus @default(AMAN)
  latitude                Float?
  longitude               Float?
  familyCount             Int         @default(0) // jumlah kepala keluarga
  deathCount              Int         @default(0) // total korban jiwa
  evacueeCount            Int         @default(0) // jumlah warga ngungsi
  injuredCount            Int         @default(0) // luka-luka
  submergedHouses         Int         @default(0) // rumah terendam
  heavilyDamagedHouses    Int         @default(0) // rumah rusak parah
  damagedPublicFacilities Int         @default(0) // fasilitas umum rusak
  damagedWorshipPlaces    Int         @default(0) // tempat ibadah rusak
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

// existing models
model FloodAlert {
  id          Int      @id @default(autoincrement())
  location    String
  waterLevel  Float
  severity    String
  status      String   @default("active")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Infographic {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String
  linkUrl     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, sortOrder])
}

model BbwsStation {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  riverName String?
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readings  BbwsWaterLevel[]
  debits    BbwsDebit[]      // Relasi baru untuk debit
  rainfalls BbwsRainfall[]   // Relasi baru untuk curah hujan

  @@index([isActive])
}

model BbwsWaterLevel {
  id         Int         @id @default(autoincrement())
  stationId  Int
  waterLevel Float
  measuredAt DateTime
  source     String      @default("BBWS")
  createdAt  DateTime    @default(now())

  station BbwsStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, measuredAt])
  @@index([stationId, measuredAt])
  @@index([measuredAt])
}

model BbwsDebit {
  id         Int         @id @default(autoincrement())
  stationId  Int
  debit      Float       // Satuan m³/s
  measuredAt DateTime
  createdAt  DateTime    @default(now())

  station    BbwsStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, measuredAt])
  @@index([stationId, measuredAt])
  @@index([measuredAt])
}

model BbwsRainfall {
  id         Int         @id @default(autoincrement())
  stationId  Int
  rainfall   Float       // Satuan mm
  measuredAt DateTime
  createdAt  DateTime    @default(now())

  station    BbwsStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, measuredAt])
  @@index([stationId, measuredAt])
  @@index([measuredAt])
}

model BmkgStation {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weathers  BmkgWeather[]
  rainfalls BmkgRainfall[]

  @@index([isActive])
}

model BmkgWeather {
  id          Int         @id @default(autoincrement())
  stationId   Int
  temperature Float       // Suhu dalam °C
  windSpeed   Float       // Kecepatan angin
  forecast    String      // Status: Cerah/Berawan/Hujan
  notes       String?     @db.Text
  measuredAt  DateTime
  createdAt   DateTime    @default(now())

  station     BmkgStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, measuredAt])
  @@index([stationId, measuredAt])
  @@index([measuredAt])
}

model BmkgRainfall {
  id         Int         @id @default(autoincrement())
  stationId  Int
  rainfall   Float       // Satuan mm
  measuredAt DateTime
  createdAt  DateTime    @default(now())

  station    BmkgStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, measuredAt])
  @@index([stationId, measuredAt])
  @@index([measuredAt])
}