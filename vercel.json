{
  "version": 2,
  "buildCommand": "npm run prisma:generate && npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "index.js": {
      "memory": 1024,
      "maxDuration": 60,
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    {
      "path": "/api/bbws/sync",
      "schedule": "0 */12 * * *"
    }
  ]
}
